{
  "name": "playwright-framework",
  "version": "2.0.0",
  "description": "AI-Enhanced Playwright Testing Framework with Smart Locators, Self-Healing Tests, and Auto-Generation",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:iqm": "playwright test --config=playwright.iqm.config.js",
    "test:iqm:ui": "playwright test --config=playwright.iqm.config.js --ui",
    "test:iqm:headed": "HEADED=true playwright test --config=playwright.iqm.config.js",
    "test:iqm:debug": "playwright test --config=playwright.iqm.config.js --debug",
    "test:iqm:ci": "CI=true playwright test --config=playwright.iqm.config.js",
    "test:iqm:parallel": "playwright test --config=playwright.iqm.config.js --workers=4",
    "test:synack": "playwright test --config=playwright.config.js",
    "report": "playwright show-report",
    "codegen": "playwright codegen",
    "codegen:iqm": "playwright codegen https://apitesting.stage.iqm.com/",
    "record": "node scripts/record-test.js",
    "record:help": "node scripts/record-test.js help",
    "dashboard": "node test-runner-server.js",
    "dashboard:dev": "nodemon test-runner-server.js"
  },
  "keywords": [
    "playwright",
    "testing",
    "automation",
    "ai",
    "self-healing",
    "test-generation",
    "qa"
  ],
  "author": "Maulik Shah",
  "license": "ISC",
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "@playwright/test": "^1.57.0",
    "express": "^4.22.1",
    "nodemon": "^3.1.14",
    "ws": "^8.20.0"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  }
}
