# IQM Testing Credentials
# Copy this file to .env and fill in your credentials

# IQM Application Credentials
IQM_USERNAME=your_email@example.com
IQM_PASSWORD=your_password

# Optional: Test Configuration
# HEADED=true          # Run tests in headed mode (see browser)
# CI=true              # Run tests in CI mode (with retries)
# DEBUG=true           # Run tests in debug mode
